#!/usr/bin/env python3
import sys
import zipfile
import os

def create_zip(source_dir, output_file):
    """Create a zip file from a directory"""
    zipf = zipfile.ZipFile(output_file, 'w', zipfile.ZIP_DEFLATED)
    
    for root, dirs, files in os.walk(source_dir):
        for file in files:
            file_path = os.path.join(root, file)
            arcname = os.path.relpath(file_path, source_dir)
            zipf.write(file_path, arcname)
    
    zipf.close()

if __name__ == "__main__":
    # Mimic zip command line interface
    if len(sys.argv) < 3:
        print("Usage: zip <output_file> <source_dir>")
        sys.exit(1)
    
    output_file = sys.argv[1]
    source_dir = sys.argv[2]
    
    create_zip(source_dir, output_file)
    print(f"Created {output_file} from {source_dir}")
